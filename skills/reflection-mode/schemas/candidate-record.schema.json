{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codeime.github.io/reflection-mode/skills/reflection-mode/schemas/candidate-record.schema.json",
  "title": "Reflection Mode candidate record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "created_at",
    "last_seen",
    "decision",
    "signal_strength",
    "evidence_count",
    "correction_count",
    "experience_type",
    "scope",
    "queue_scope",
    "project_id",
    "canonical_key",
    "lesson_hash",
    "stale_after_days",
    "applies_to",
    "lesson",
    "next_action",
    "target",
    "evidence",
    "provisional",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^reflection-candidate-[A-Za-z0-9._:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_seen": {
      "type": "string",
      "format": "date-time"
    },
    "decision": {
      "type": "string",
      "enum": ["candidate"]
    },
    "signal_strength": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 0
    },
    "correction_count": {
      "type": "integer",
      "minimum": 0
    },
    "experience_type": {
      "type": "string",
      "enum": ["preference", "repo-contract", "process", "review-rule", "code-pattern", "other"]
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "queue_scope": {
      "type": "string",
      "enum": ["project", "global"]
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_key": {
      "type": "string",
      "minLength": 1
    },
    "lesson_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{12,64}$"
    },
    "stale_after_days": {
      "type": "integer",
      "minimum": 1
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lesson": {
      "type": "string",
      "minLength": 1
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "enum": ["memory", "skill-reference", "project-doc", "candidate-queue", "other"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_type",
          "summary"
        ],
        "properties": {
          "source_type": {
            "type": "string",
            "enum": [
              "user_correction",
              "test_failure",
              "command_output",
              "review_finding",
              "prior_candidate",
              "manual_request",
              "agent_observation",
              "other"
            ]
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "code_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "pattern",
        "applies_when",
        "does_not_apply_when"
      ],
      "properties": {
        "language": {
          "type": "string",
          "minLength": 1
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "applies_when": {
          "type": "string",
          "minLength": 1
        },
        "does_not_apply_when": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provisional": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "confirmed", "skipped", "written", "stale_review"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "experience_type": {
            "const": "code-pattern"
          }
        },
        "required": ["experience_type"]
      },
      "then": {
        "required": ["code_pattern"]
      }
    },
    {
      "if": {
        "required": ["code_pattern"]
      },
      "then": {
        "properties": {
          "experience_type": {
            "const": "code-pattern"
          }
        }
      }
    }
  ]
}
