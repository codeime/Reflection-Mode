{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codeime.github.io/reflection-mode/schemas/event-record.schema.json",
  "title": "Reflection Mode event record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "created_at",
    "event_type",
    "scope",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^reflection-event-[A-Za-z0-9._:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "candidate_created",
        "candidate_confirmed",
        "candidate_skipped",
        "lesson_written",
        "lesson_applied",
        "stale_review"
      ]
    },
    "candidate_id": {
      "type": "string"
    },
    "lesson_id": {
      "type": "string"
    },
    "signal_strength": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string"
    }
  }
}
